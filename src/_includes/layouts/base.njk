<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ description or site.tagline }}">
  <title>{% if title %}{{ title }} | {% endif %}{{ site.businessName }}</title>
  <link rel="icon" href="{{ site.faviconPath }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/main.css">
  {% if site.analyticsId %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analyticsId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.analyticsId }}');
  </script>
  {% endif %}
</head>
<body class="{{ bodyClass or '' }}">
  <div class="site-shell">
    {% include "partials/nav.njk" %}
    <main>
      {{ content | safe }}
    </main>
    {% include "partials/footer.njk" %}
  </div>

  <script src="/assets/js/site.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  {% if useBookingScripts %}
  <script src="/shared/template-config.js"></script>
  <script src="/shared/booking-rules.js"></script>
  <script src="/assets/js/booking.js"></script>
  {% endif %}
  {% if useContactScripts %}
  <script src="/assets/js/contact.js"></script>
  {% endif %}
</body>
</html>
