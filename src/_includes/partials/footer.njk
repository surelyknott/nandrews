<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="footer-title">{{ site.businessName }}</p>
      {% for line in site.addressLines %}
      <p class="footer-copy">{{ line }}</p>
      {% endfor %}
    </div>

    <div>
      <p class="footer-title">Quick links</p>
      <ul class="footer-links">
        {% for item in navigation %}
        <li><a href="{{ item.url }}">{{ item.label }}</a></li>
        {% endfor %}
      </ul>
    </div>

    <div>
      <p class="footer-title">Phone</p>
      <ul class="footer-links">
        {% if site.contactEmail %}
        <li><a href="mailto:{{ site.contactEmail }}">{{ site.contactEmail }}</a></li>
        {% endif %}
        <li><a href="tel:{{ site.contactPhoneHref or site.contactPhone }}">{{ site.contactPhone }}</a></li>
      </ul>
      <div class="footer-socials">
        {% for social in site.socials %}
        <a href="{{ social.url }}" target="_blank" rel="noopener">{{ social.label }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>© <span id="y"></span> {{ site.businessName }}. Website by SurelyKnott</span>
  </div>
</footer>
